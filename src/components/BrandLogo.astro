---
/**
 * BrandLogo - ServicesInMyCity brand logo component
 * Renders the appropriate logo variant with graceful fallback
 * variant="light"  횄짖횂혛횂혪 white/reversed logo (for dark/navy backgrounds)
 * variant="dark"   횄짖횂혛횂혪 full-color logo (for light backgrounds)
 */
import SafeImage from "./SafeImage.astro";

interface Props {
  variant?: "light" | "dark";
  width?: number | string;
  height?: number | string;
  class?: string;
}

const {
  variant = "light",
  width = 160,
  height = "auto",
  class: className = "",
} = Astro.props;

const logoSrc =
  variant === "dark"
    ? "/assets/brand/logo-servicesinmycity.png"
    : "/assets/brand/logo-servicesinmycity.png";

const logoAlt = "ServicesInMyCity";
---

<SafeImage
  src={logoSrc}
  alt={logoAlt}
  width={width}
  height={height}
  class={`brand-logo brand-logo--${variant} ${className}`.trim()}
/>

<style>
  .brand-logo {
    display: block;
    max-width: 100%;
  }
  /* Temporary: no dedicated white/reversed logo yet.
     When the logo sits on the dark footer, render the full-color PNG
     through a CSS filter so it reads as a clean white mark.
     Replace with a real reversed asset later. */
  :global(footer .brand-logo) {
    filter: brightness(0) invert(1);
  }
</style>

---
/**
 * SafeImage - Fallback-aware image component
 * Displays brand images with fallback to branded placeholder
 * No broken image icons, no layout shift
 */
interface Props {
  src: string;
  alt: string;
  title?: string;
  width?: number | string;
  height?: number | string;
  class?: string;
  role?: string;
}

const {
  src,
  alt,
  title,
  width = "auto",
  height = "auto",
  class: className = "",
  role = "img",
} = Astro.props;
---

<img
  src={src}
  alt={alt}
  title={title}
  width={width}
  height={height}
  class={`safe-image ${className}`}
  role={role}
  onerror="this.style.display='none'; this.nextElementSibling && this.nextElementSibling.style.display='flex';"
/>

<!-- Fallback placeholder - branded navy/orange -->
<div
  class={`image-fallback ${className}`}
  style={{
    display: "none",
    width: width === "auto" ? "100%" : width,
    height: height === "auto" ? "auto" : height,
  }}
  aria-label={alt}
  role={role}
>
  <div class="fallback-content">
    <span class="fallback-text">{alt}</span>
  </div>
</div>

<style>
  .image-fallback {
    background: linear-gradient(135deg, #002b5f 0%, #ff6633 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    color: white;
    font-size: 0.875rem;
    font-weight: 500;
    text-align: center;
    padding: 16px;
    min-height: 80px;
  }

  .fallback-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .fallback-text {
    font-size: 0.75rem;
    opacity: 0.9;
  }

  .safe-image {
    display: block;
    max-width: 100%;
    height: auto;
  }
</style>

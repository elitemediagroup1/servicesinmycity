---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found" description="That page doesn't exist. Ask Rocco instead.">
  <section class="hero">
    <div class="container">
      <h1>Hmm, that page took a day off.</h1>
      <p class="lede">We couldn't find what you were looking for. No problem &mdash; let's get you back on track.</p>
      <div style="margin-top:20px">
        <a class="btn btn-primary" href="/ask">Ask Rocco</a>
        <a class="btn btn-secondary" href="/" style="margin-left:10px">Go home</a>
      </div>
    </div>
  </section>
</BaseLayout>

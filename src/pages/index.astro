---
import BaseLayout from '../layouts/BaseLayout.astro';
import SafeImage from "../components/SafeImage.astro";

/* PHASE 2.5 - Polish pass. Homepage as a living product experience.
   No fabricated stats/reviews. Only real asset is the Rocco headshot;
   the interactive house is pure SVG/CSS so it is premium and art-independent.
   Backend (functions, sessions, consent, ARS, Rocco intelligence) untouched. */

const services = [
  { slug: 'hvac',       label: 'Heating &amp; Cooling', hint: 'No heat, no cool, weird noises' },
  { slug: 'plumbing',   label: 'Plumbing',              hint: 'Leaks, clogs, water heaters' },
  { slug: 'electrical', label: 'Electrical',            hint: 'Breakers, outlets, panels' },
  { slug: 'roofing',    label: 'Roofing',               hint: 'Leaks, shingles, storm damage' },
];

/* House hotspots positioned over the SVG home (x/y are % within the stage).
   Each deep-links into Ask Rocco with topic context. */
const hotspots = [
  { key: 'roof',       label: 'Roof',       x: 50, y: 10 },
  { key: 'attic',      label: 'Attic',      x: 50, y: 25 },
  { key: 'windows',    label: 'Windows',    x: 27, y: 50 },
  { key: 'hvac',       label: 'HVAC',       x: 84, y: 64 },
  { key: 'electrical', label: 'Electrical', x: 70, y: 46 },
  { key: 'kitchen',    label: 'Kitchen',    x: 38, y: 62 },
  { key: 'bathroom',   label: 'Bathroom',   x: 62, y: 62 },
  { key: 'plumbing',   label: 'Plumbing',   x: 50, y: 76 },
  { key: 'garage',     label: 'Garage',     x: 16, y: 72 },
  { key: 'foundation', label: 'Foundation', x: 50, y: 92 },
  { key: 'basement',   label: 'Basement',   x: 33, y: 88 },
  { key: 'outside',    label: 'Outside',    x: 89, y: 88 },
];

const prompts = [
  'My AC is blowing warm air',
  'Brown stain on my ceiling',
  'My breaker keeps tripping',
  'Water pressure dropped',
];
---

<BaseLayout title="The home guide that knows what&rsquo;s wrong" description="ServicesInMyCity is the AI guide for your home. Ask Rocco what&rsquo;s wrong before anyone touches it &mdash; then connect with a trusted local pro.">

  <!-- ===================== HERO ===================== -->
  <section class="hero2" aria-label="Ask Rocco">
    <div class="hero2-aurora" aria-hidden="true"></div>
    <div class="hero2-grain" aria-hidden="true"></div>
    <div class="hero2-inner">
      <p class="hero2-eyebrow reveal">The AI guide for your home</p>
      <h1 class="hero2-title reveal">
        Know what&rsquo;s wrong with your home<br />
        <span class="hero2-title-accent">before anyone touches it.</span>
      </h1>
      <p class="hero2-lede reveal">
        Describe what&rsquo;s happening in plain words. Rocco helps you understand it,
        what it might cost, and what to ask &mdash; then connects you with a trusted local pro.
      </p>

      <form class="askbar reveal" action="/ask" method="get" role="search">
        <span class="askbar-rocco" aria-hidden="true">
          <img src="/assets/rocco/rocco-headshot.png" alt="" width="40" height="40" />
          <span class="askbar-pulse"></span>
        </span>
        <input class="askbar-input" type="text" name="q" autocomplete="off"
          aria-label="Describe what is happening with your home"
          placeholder="" data-greeting="1" />
        <button class="askbar-go" type="submit">
          Ask Rocco
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </form>

      <div class="hero2-prompts reveal" aria-label="Examples">
        {prompts.map((p) => (
          <a class="chip" href={`/ask?q=${encodeURIComponent(p)}`}>{p}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== THE HOUSE ===================== -->
  <section class="house2" aria-labelledby="house2-title">
    <div class="house2-head reveal">
      <h2 id="house2-title" class="house2-title">Point to where it hurts.</h2>
      <p class="house2-sub">Every part of your home is a question Rocco can answer. Hover a spot &mdash; then ask.</p>
    </div>

    <div class="stage reveal" id="stage" data-parallax>
      <!-- ambient sky + drifting clouds -->
      <div class="sky" aria-hidden="true">
        <span class="cloud cloud-a"></span>
        <span class="cloud cloud-b"></span>
        <span class="cloud cloud-c"></span>
        <span class="bird" aria-hidden="true"></span>
      </div>

      <!-- the home itself (breathes + parallax) -->
      <div class="home-wrap" data-depth="0.4">
        <span class="chimney-smoke" aria-hidden="true"><i></i><i></i><i></i></span>
        <svg class="stage-house" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Illustrated home">
          <defs>
            <linearGradient id="wallG" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#FBFAF7"/>
              <stop offset="1" stop-color="#ECE7DD"/>
            </linearGradient>
            <linearGradient id="roofG" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#22405F"/>
              <stop offset="1" stop-color="#16304C"/>
            </linearGradient>
            <radialGradient id="winG" cx="0.5" cy="0.4" r="0.7">
              <stop offset="0" stop-color="#FFE6B8"/>
              <stop offset="1" stop-color="#F4A24B"/>
            </radialGradient>
            <filter id="soft" x="-20%" y="-20%" width="140%" height="140%">
              <feDropShadow dx="0" dy="1.2" stdDeviation="1.4" flood-color="#16304C" flood-opacity="0.18"/>
            </filter>
          </defs>
          <!-- ground shadow -->
          <ellipse cx="50" cy="95" rx="40" ry="3.4" fill="#16304C" opacity="0.12"/>
          <!-- body -->
          <g filter="url(#soft)">
            <rect x="20" y="40" width="60" height="48" rx="2.5" fill="url(#wallG)"/>
            <!-- roof -->
            <path d="M14 42 L50 14 L86 42 Z" fill="url(#roofG)"/>
            <!-- chimney -->
            <rect x="64" y="22" width="7" height="14" rx="1" fill="#22405F"/>
            <!-- door -->
            <rect x="45" y="64" width="10" height="24" rx="1.4" fill="#22405F"/>
            <circle cx="53" cy="76" r="0.8" fill="#F4A24B"/>
            <!-- porch light glow -->
            <circle class="porch" cx="42" cy="62" r="1.4" fill="#F4A24B"/>
            <!-- windows (glow + pulse) -->
            <rect class="win" x="26" y="48" width="9" height="9" rx="1" fill="url(#winG)"/>
            <rect class="win win-2" x="65" y="48" width="9" height="9" rx="1" fill="url(#winG)"/>
            <rect class="win win-3" x="26" y="70" width="9" height="9" rx="1" fill="url(#winG)"/>
            <rect class="win win-4" x="65" y="70" width="9" height="9" rx="1" fill="url(#winG)"/>
            <!-- window frames -->
            <g stroke="#22405F" stroke-width="0.6" opacity="0.5">
              <line x1="30.5" y1="48" x2="30.5" y2="57"/><line x1="26" y1="52.5" x2="35" y2="52.5"/>
              <line x1="69.5" y1="48" x2="69.5" y2="57"/><line x1="65" y1="52.5" x2="74" y2="52.5"/>
              <line x1="30.5" y1="70" x2="30.5" y2="79"/><line x1="26" y1="74.5" x2="35" y2="74.5"/>
              <line x1="69.5" y1="70" x2="69.5" y2="79"/><line x1="65" y1="74.5" x2="74" y2="74.5"/>
            </g>
          </g>
        </svg>
      </div>

      <!-- interactive hotspots -->
      <div class="hotspots">
        {hotspots.map((h) => (
          <a class="hotspot" href={`/ask?topic=${encodeURIComponent(h.label)}`}
             style={`left:${h.x}%;top:${h.y}%`} aria-label={`Ask Rocco about ${h.label}`}>
            <span class="hotspot-dot" aria-hidden="true"></span>
            <span class="hotspot-label">{h.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== JOURNEY (a moment) ===================== -->
  <section class="journey" aria-labelledby="journey-title">
    <div class="journey-head reveal">
      <p class="eyebrow">How it feels</p>
      <h2 id="journey-title" class="journey-title">From &ldquo;what is that noise?&rdquo;<br />to a pro you trust.</h2>
    </div>
    <div class="journey-track">
      <div class="jstep reveal">
        <span class="jstep-num">01</span>
        <h3>You notice something</h3>
        <p>A stain, a sound, a smell. You don&rsquo;t need the right words &mdash; just describe it.</p>
      </div>
      <span class="journey-arrow" aria-hidden="true">
        <svg width="44" height="16" viewBox="0 0 44 16" fill="none"><path d="M0 8h40M34 2l8 6-8 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
      <div class="jstep reveal">
        <span class="jstep-num">02</span>
        <h3>Rocco helps you understand</h3>
        <p>What it likely is, what it tends to cost, and the right questions to ask. No pressure, no upsell.</p>
      </div>
      <span class="journey-arrow" aria-hidden="true">
        <svg width="44" height="16" viewBox="0 0 44 16" fill="none"><path d="M0 8h40M34 2l8 6-8 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
      <div class="jstep reveal">
        <span class="jstep-num">03</span>
        <h3>You meet a trusted local pro</h3>
        <p>When you&rsquo;re ready, Rocco connects you with a vetted professional near you &mdash; on your terms.</p>
      </div>
    </div>
  </section>

  <!-- ===================== SERVICES ===================== -->
  <section class="services2" aria-labelledby="services2-title">
    <div class="services2-head reveal">
      <p class="eyebrow">Where Rocco helps</p>
      <h2 id="services2-title" class="services2-title">Starting with the things that go wrong most.</h2>
    </div>
    <div class="services2-grid">
      {services.map((s) => (
        <a class="scard reveal" href={`/services/${s.slug}`}>
          <span class="scard-glow" aria-hidden="true"></span>
          <span class="scard-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M4 13l5 5L20 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <h3 class="scard-title" set:html={s.label}></h3>
          <p class="scard-hint">{s.hint}</p>
          <span class="scard-go">Ask Rocco &rarr;</span>
        </a>
      ))}
    </div>
    <p class="services2-all reveal"><a href="/services">See everything Rocco can help with &rarr;</a></p>
  </section>

  <!-- ===================== ROCCO BAND ===================== -->
  <section class="roccoband" aria-labelledby="roccoband-title">
    <div class="roccoband-inner reveal">
      <div class="roccoband-portrait" aria-hidden="true">
        <img src="/assets/rocco/rocco-headshot.png" alt="" width="200" height="200" />
        <span class="roccoband-ring"></span>
      </div>
      <div class="roccoband-copy">
        <p class="eyebrow eyebrow-light">Meet Rocco</p>
        <h2 id="roccoband-title">He works for you &mdash; not the contractor.</h2>
        <p>Rocco doesn&rsquo;t sell you anything. He helps you understand your home, so you walk into every repair informed, calm, and in control.</p>
        <a class="btn-light" href="/ask">Start a conversation</a>
      </div>
    </div>
  </section>

  <!-- ===================== CLOSING ===================== -->
  <section class="closing2 reveal" aria-labelledby="closing2-title">
    <h2 id="closing2-title" class="closing2-title">Your home has a guide now.</h2>
    <a class="btn-primary btn-xl" href="/ask">Ask Rocco a question</a>
    <p class="closing2-area">Serving the Jersey Shore launch area &mdash; Stafford, Manahawkin, Barnegat, LBI, Toms River, Forked River, Waretown and more. If we can&rsquo;t help in your town yet, Rocco will tell you straight.</p>
  </section>

</BaseLayout>

<style>
  /* ============ shared rhythm ============ */
  .eyebrow{font-size:.82rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--emg-orange,#E8762B);margin:0 0 .9rem}
  .eyebrow-light{color:#F4A24B}
  .reveal{opacity:0;transform:translateY(26px);transition:opacity .9s cubic-bezier(.2,.7,.2,1),transform .9s cubic-bezier(.2,.7,.2,1)}
  .reveal.in{opacity:1;transform:none}
  :focus-visible{outline:3px solid #F4A24B;outline-offset:3px;border-radius:6px}

  /* ============ HERO ============ */
  .hero2{position:relative;overflow:hidden;text-align:center;padding:clamp(5rem,11vw,9rem) 1.4rem clamp(3.5rem,7vw,6rem);background:linear-gradient(180deg,#FBF8F2 0%,#F6F1E8 100%)}
  .hero2-aurora{position:absolute;inset:-30% -10% auto -10%;height:80%;background:
    radial-gradient(40% 60% at 25% 30%,rgba(244,162,75,.30),transparent 70%),
    radial-gradient(45% 55% at 78% 20%,rgba(34,64,95,.18),transparent 70%),
    radial-gradient(40% 50% at 60% 65%,rgba(58,160,160,.16),transparent 70%);
    filter:blur(20px);animation:auroraDrift 22s ease-in-out infinite alternate}
  @keyframes auroraDrift{0%{transform:translate3d(0,0,0) scale(1)}100%{transform:translate3d(2.5%,2%,0) scale(1.08)}}
  .hero2-grain{position:absolute;inset:0;opacity:.5;pointer-events:none;mix-blend-mode:soft-light;background-image:radial-gradient(rgba(0,0,0,.18) .5px,transparent .5px);background-size:3px 3px}
  .hero2-inner{position:relative;max-width:980px;margin:0 auto}
  .hero2-eyebrow{font-size:.84rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--emg-orange,#E8762B);margin:0 0 1.2rem}
  .hero2-title{font-size:clamp(2.8rem,7vw,5.6rem);line-height:1.02;letter-spacing:-.025em;font-weight:800;color:#16304C;margin:0 0 1.4rem}
  .hero2-title-accent{color:var(--emg-orange,#E8762B)}
  .hero2-lede{font-size:clamp(1.1rem,2.2vw,1.45rem);line-height:1.55;color:#42546A;max-width:720px;margin:0 auto 2.6rem}

  /* ask bar with living Rocco */
  .askbar{display:flex;align-items:center;gap:.5rem;max-width:680px;margin:0 auto;background:#fff;border:1px solid rgba(22,48,76,.10);border-radius:999px;padding:.5rem .5rem .5rem .55rem;box-shadow:0 24px 60px -28px rgba(22,48,76,.45),0 2px 8px rgba(22,48,76,.06);transition:box-shadow .4s ease,transform .4s ease,border-color .4s ease}
  .askbar:focus-within{box-shadow:0 30px 70px -26px rgba(232,118,43,.5),0 0 0 4px rgba(244,162,75,.18);border-color:rgba(244,162,75,.55);transform:translateY(-2px)}
  .askbar-rocco{position:relative;flex:0 0 auto;width:40px;height:40px}
  .askbar-rocco img{width:40px;height:40px;border-radius:50%;object-fit:cover;animation:roccoFloat 5s ease-in-out infinite}
  @keyframes roccoFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-3px)}}
  .askbar-pulse{position:absolute;right:1px;bottom:1px;width:10px;height:10px;border-radius:50%;background:#3AA0A0;box-shadow:0 0 0 2px #fff}
  .askbar-pulse::after{content:"";position:absolute;inset:0;border-radius:50%;background:#3AA0A0;animation:livePulse 2.4s ease-out infinite}
  @keyframes livePulse{0%{transform:scale(1);opacity:.6}100%{transform:scale(2.8);opacity:0}}
  .askbar-input{flex:1;border:0;background:transparent;font-size:1.05rem;color:#16304C;padding:.5rem .4rem}
  .askbar-input:focus{outline:none}
  .askbar-input::placeholder{color:#8696A8}
  .askbar-go{flex:0 0 auto;display:inline-flex;align-items:center;gap:.4rem;border:0;cursor:pointer;background:var(--emg-orange,#E8762B);color:#fff;font-weight:700;font-size:1rem;padding:.7rem 1.2rem;border-radius:999px;transition:transform .25s cubic-bezier(.2,.7,.2,1),box-shadow .25s,background .25s}
  .askbar-go:hover{transform:translateY(-1px) scale(1.02);box-shadow:0 12px 26px -10px rgba(232,118,43,.6);background:#F4882F}
  .askbar-go svg{transition:transform .25s}
  .askbar-go:hover svg{transform:translateX(3px)}
  .hero2-prompts{display:flex;flex-wrap:wrap;gap:.6rem;justify-content:center;margin-top:1.6rem}
  .chip{font-size:.92rem;color:#42546A;background:rgba(255,255,255,.7);border:1px solid rgba(22,48,76,.10);padding:.5rem .95rem;border-radius:999px;text-decoration:none;transition:all .25s cubic-bezier(.2,.7,.2,1)}
  .chip:hover{color:#16304C;background:#fff;border-color:rgba(244,162,75,.6);transform:translateY(-2px);box-shadow:0 10px 22px -12px rgba(22,48,76,.35)}

  /* ============ THE HOUSE ============ */
  .house2{padding:clamp(4rem,9vw,8rem) 1.4rem;background:#16304C;color:#fff;text-align:center;position:relative;overflow:hidden}
  .house2-head{max-width:760px;margin:0 auto clamp(2rem,5vw,3.5rem)}
  .house2-title{font-size:clamp(2.2rem,5.5vw,4rem);line-height:1.05;letter-spacing:-.02em;font-weight:800;margin:0 0 1rem}
  .house2-sub{font-size:clamp(1rem,2vw,1.25rem);color:#A9BBD0;margin:0}
  .stage{position:relative;max-width:760px;margin:0 auto;aspect-ratio:1/.84;border-radius:28px;background:linear-gradient(180deg,#2B4A6E 0%,#15314E 100%)}
  .stage{box-shadow:inset 0 1px 0 rgba(255,255,255,.06),0 40px 90px -40px rgba(0,0,0,.6);overflow:hidden}
  .sky{position:absolute;inset:0;overflow:hidden;border-radius:28px}
  .cloud{position:absolute;background:radial-gradient(circle at 30% 50%,rgba(255,255,255,.16),rgba(255,255,255,.05) 70%,transparent 72%);border-radius:50%;filter:blur(2px)}
  .cloud-a{width:120px;height:46px;top:14%;left:-20%;animation:drift 38s linear infinite}
  .cloud-b{width:90px;height:36px;top:26%;left:-30%;opacity:.7;animation:drift 52s linear infinite 6s}
  .cloud-c{width:150px;height:54px;top:8%;left:-40%;opacity:.5;animation:drift 64s linear infinite 12s}
  @keyframes drift{from{transform:translateX(0)}to{transform:translateX(160vw)}}
  .bird{position:absolute;top:18%;left:-10%;width:10px;height:10px;opacity:.5;animation:fly 26s linear infinite 9s}
  .bird::before,.bird::after{content:"";position:absolute;top:0;width:7px;height:2px;border-radius:50%;background:#0E2237}
  .bird::before{left:-5px;transform:rotate(18deg)}
  .bird::after{left:1px;transform:rotate(-18deg)}
  @keyframes fly{0%{transform:translate(0,0)}50%{transform:translate(60vw,-22px)}100%{transform:translate(130vw,8px)}}
  .home-wrap{position:absolute;inset:0;display:grid;place-items:center;will-change:transform;transition:transform .25s ease-out}
  .stage-house{width:74%;height:auto;transform-origin:50% 90%;animation:breathe 6.5s ease-in-out infinite}
  @keyframes breathe{0%,100%{transform:scale(1)}50%{transform:scale(1.012)}}
  .win{transform-origin:center;animation:winGlow 5s ease-in-out infinite}
  .win-2{animation-delay:.8s}.win-3{animation-delay:1.6s}.win-4{animation-delay:2.4s}
  @keyframes winGlow{0%,100%{opacity:.82;filter:drop-shadow(0 0 .4px #F4A24B)}50%{opacity:1;filter:drop-shadow(0 0 1.6px #FFCB7A)}}
  .porch{animation:porchGlow 4s ease-in-out infinite;filter:drop-shadow(0 0 1.4px #F4A24B)}
  @keyframes porchGlow{0%,100%{opacity:.7}50%{opacity:1}}
  .chimney-smoke{position:absolute;left:60.5%;top:14%;width:14px;height:60px;pointer-events:none}
  .chimney-smoke i{position:absolute;bottom:0;left:4px;width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,.16);animation:smoke 6s ease-in infinite}
  .chimney-smoke i:nth-child(2){animation-delay:2s}
  .chimney-smoke i:nth-child(3){animation-delay:4s}
  @keyframes smoke{0%{transform:translate(0,0) scale(.6);opacity:0}20%{opacity:.5}100%{transform:translate(-10px,-52px) scale(2.4);opacity:0}}

  /* hotspots */
  .hotspots{position:absolute;inset:0}
  .hotspot{position:absolute;transform:translate(-50%,-50%);text-decoration:none}
  .hotspot-dot{display:block;width:16px;height:16px;border-radius:50%;background:var(--emg-orange,#E8762B);box-shadow:0 0 0 0 rgba(232,118,43,.55);transition:transform .3s cubic-bezier(.2,.7,.2,1);animation:dotPulse 2.6s ease-out infinite}
  @keyframes dotPulse{0%{box-shadow:0 0 0 0 rgba(232,118,43,.5)}70%{box-shadow:0 0 0 12px rgba(232,118,43,0)}100%{box-shadow:0 0 0 0 rgba(232,118,43,0)}}
  .hotspot-label{position:absolute;left:50%;bottom:calc(100% + 9px);transform:translateX(-50%) translateY(6px);white-space:nowrap;background:#fff;color:#16304C;font-size:.8rem;font-weight:700;padding:.32rem .7rem;border-radius:999px;opacity:0;pointer-events:none;transition:opacity .25s,transform .25s;box-shadow:0 8px 20px -8px rgba(0,0,0,.5)}
  .hotspot:hover .hotspot-dot,.hotspot:focus-visible .hotspot-dot{transform:scale(1.45)}
  .hotspot:hover .hotspot-label,.hotspot:focus-visible .hotspot-label{opacity:1;transform:translateX(-50%) translateY(0)}

  /* ============ JOURNEY ============ */
  .journey{padding:clamp(4.5rem,9vw,8rem) 1.4rem;background:#FBF8F2;text-align:center}
  .journey-head{max-width:760px;margin:0 auto clamp(2.4rem,5vw,4rem)}
  .journey-title{font-size:clamp(2rem,5vw,3.6rem);line-height:1.08;letter-spacing:-.02em;font-weight:800;color:#16304C;margin:0}
  .journey-track{display:flex;align-items:stretch;justify-content:center;gap:1.4rem;flex-wrap:wrap;max-width:1080px;margin:0 auto}
  .jstep{flex:1 1 260px;max-width:320px;text-align:left;background:#fff;border:1px solid rgba(22,48,76,.07);border-radius:20px;padding:2rem 1.7rem;box-shadow:0 30px 60px -42px rgba(22,48,76,.4);transition:transform .4s cubic-bezier(.2,.7,.2,1),box-shadow .4s}
  .jstep:hover{transform:translateY(-6px);box-shadow:0 40px 70px -38px rgba(22,48,76,.5)}
  .jstep-num{display:inline-block;font-size:.85rem;font-weight:800;letter-spacing:.1em;color:var(--emg-orange,#E8762B);background:rgba(232,118,43,.10);padding:.3rem .6rem;border-radius:8px;margin-bottom:1rem}
  .jstep h3{font-size:1.3rem;color:#16304C;margin:0 0 .6rem;letter-spacing:-.01em}
  .jstep p{font-size:1.02rem;line-height:1.55;color:#52647A;margin:0}

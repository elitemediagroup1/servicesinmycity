    .btn-ghost { display: inline-flex; align-items: center; gap: 6px; color: #fff; font-weight: 700; text-decoration: none;
      border: 1.5px solid rgba(255,255,255,0.4); padding: 12px 22px; border-radius: var(--radius-pill); transition: all var(--dur-standard) var(--ease-out); }

<script is:inline>
  (function () {
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* scroll reveal */
    var items = document.querySelectorAll('.reveal');
    if ('IntersectionObserver' in window && !reduce) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.14 });
      items.forEach(function (el) { io.observe(el); });
    } else {
      items.forEach(function (el) { el.classList.add('in'); });
    }

    /* time-based greeting typed into the ask bar placeholder */
    var input = document.querySelector('[data-greeting]');
    if (input) {
      var h = new Date().getHours();
      var part = h < 12 ? 'morning' : (h < 18 ? 'afternoon' : 'evening');
      var msg = 'Good ' + part + ' \u2014 what is going on with your home?';
      if (reduce) {
        input.setAttribute('placeholder', msg);
      } else {
        var i = 0;
        (function typeIt() {
          input.setAttribute('placeholder', msg.slice(0, i) + (i < msg.length ? '\u2502' : ''));
          if (i <= msg.length) { i++; setTimeout(typeIt, 38); }
          else { input.setAttribute('placeholder', msg); }
        })();
      }
    }

    /* gentle cursor parallax on the house */
    var stage = document.getElementById('stage');
    var wrap = stage && stage.querySelector('.home-wrap');
    if (stage && wrap && !reduce && window.matchMedia('(pointer:fine)').matches) {
      stage.addEventListener('mousemove', function (e) {
        var r = stage.getBoundingClientRect();
        var dx = (e.clientX - r.left) / r.width - 0.5;
        var dy = (e.clientY - r.top) / r.height - 0.5;
        wrap.style.transform = 'translate3d(' + (dx * 14).toFixed(1) + 'px,' + (dy * 10).toFixed(1) + 'px,0)';
      });
      stage.addEventListener('mouseleave', function () {
        wrap.style.transform = 'translate3d(0,0,0)';
      });
    }
  })();
</script>

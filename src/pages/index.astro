---
import BaseLayout from '../layouts/BaseLayout.astro';
import SafeImage from "../components/SafeImage.astro";
---
<BaseLayout title="Find trusted local pros" description="Meet Rocco, your local repair guide. Find trusted local pros and get the job done right on the Jersey Shore.">
  <section class="hero">
    <div class="container">
      <h1>Meet Rocco. Your local repair guide.</h1>
      <p class="lede">Rocco helps homeowners find trusted local repair pros, fast answers, and practical next steps &mdash; right in their city. Find. Connect. Fix.</p>
      <div style="margin-top:20px">
        <a class="btn btn-primary" href="/ask">Ask Rocco a question</a>
        <a class="btn btn-secondary" href="/services" style="margin-left:10px">Browse services</a>
      </div>
        <SafeImage
      src="/assets/rocco/rocco-hero.png"
      alt="Rocco, your local repair guide"
      width={320}
      height={320}
      class="rocco-hero-img"
    />
</div>
  </section>

  <section class="container" style="padding:48px 20px">
    <div class="grid">
      <div class="card">
        <h3>Trusted local pros</h3>
        <p>Rocco helps you find nearby businesses and ask the right questions before you hire.</p>
      </div>
      <div class="card">
        <h3>Fast home help</h3>
        <p>Quick, plain-spoken answers when you need them &mdash; no runaround.</p>
      </div>
      <div class="card">
        <h3>Practical solutions</h3>
        <p>Clear guidance and next steps you can actually use. Rocco equips you; he never diagnoses.</p>
      </div>
    </div>
  </section>

  <section class="container" style="padding:0 20px 48px">
    <h2>Popular services</h2>
    <div class="grid">
      <a class="card" href="/services/hvac">HVAC &mdash; heating &amp; cooling</a>
      <a class="card" href="/services/plumbing">Plumbing</a>
      <a class="card" href="/services/electrical">Electrical</a>
      <a class="card" href="/services">See all services &rarr;</a>
    </div>
  </section>

  <section class="container" style="padding:0 20px 64px">
    <div class="disclaimer">
      Serving the Jersey Shore launch area &mdash; Stafford, Manahawkin, Barnegat, LBI, Toms River, Forked River, Waretown and more.
      We're growing honestly: if we can't help in your town yet, Rocco will tell you straight.
    </div>
  </section>
</BaseLayout>
